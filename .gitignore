# ===========================
#  ConflictPulse .gitignore
# ===========================

# Environment variables — NEVER push these
server/.env
.env
*.env

# Node modules
node_modules/
server/node_modules/

# Build outputs
dist/
build/
.cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# GitHub Pages build
gh-pages/
